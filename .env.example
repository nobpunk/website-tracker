# Database (Prisma Postgres / PostgreSQL Connection String)
DATABASE_URL="postgres://username:password@host:port/database?sslmode=require"

# NextAuth Configuration
NEXTAUTH_SECRET="your_nextauth_secret_key"
NEXTAUTH_URL="http://localhost:3001" # Or your production URL (e.g., https://your-app.vercel.app)

# Twitter / X OAuth 2.0 Credentials (Optional, falls back to Mock Mode if not provided)
TWITTER_CLIENT_ID="your_twitter_client_id"
TWITTER_CLIENT_SECRET="your_twitter_client_secret"

# OpenAI / Custom AI API Configuration
OPENAI_API_KEY="your_openai_api_key_or_custom_router_key"
OPENAI_BASE_URL="https://agentrouter.org/v1" # Or https://api.openai.com/v1
OPENAI_MODEL="gpt-4o-mini"
